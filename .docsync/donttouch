# .docsync/donttouch
# Protected content that should not be modified without explicit intent
#
# Syntax:
#   file.md#Section     - Protect a section from modification
#   "literal string"    - Ensure this string exists somewhere
#   file.ext: "string"  - Ensure string exists in specific file

# License section must not change without explicit review
README.md#License

# License identifier must exist in README
"Apache-2.0"

# License file reference must exist
"LICENSE"
